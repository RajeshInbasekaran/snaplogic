                                        },
                                        "targetPath": {
                                            "value": "$name"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$file_properties != null &&  $file_properties.image_properties != null      ? $file_properties.image_properties.width      : null"
                                        },

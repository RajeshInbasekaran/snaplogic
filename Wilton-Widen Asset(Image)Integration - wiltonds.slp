                                        "expression": {
                                            "expression": true,
                                            "value": "$file_properties && $file_properties.format_type == \"image\"  ? \"image\"  : ($file_properties && $file_properties.format_type == \"pdf\"      ? \"document\"      : ($file_properties && $file_properties.format_type == \"audio\"         ? \"audio\"         : ($file_properties && $file_properties.format_type == \"video\"             ? \"video\"             : null)))"
                                        },
                                        "targetPath": {
                                            "value": "$type"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,

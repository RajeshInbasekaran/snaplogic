                                        "targetPath": {
                                            "value": "$attributes.property_originalfilename"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$filename"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.filename"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,

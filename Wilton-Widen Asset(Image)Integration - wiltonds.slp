                                            "value": "$attributes.imageheight"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$metadata.fields.description != null && $metadata.fields.description.length > 0 ? $metadata.fields.description[0]     .replace(/[\\u200B-\\u200D\\uFEFF]/g, \"\")     .replace(/\u00e2\u20ac\u2122/g, \"'\")     .replace(/\\u2019/g, \"'\") : null"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.description"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$metadata.fields.description != null && $metadata.fields.description.length > 0 ? $metadata.fields.description[0]     .replace(/[\\u200B-\\u200D\\uFEFF]/g, \"\")     .replace(/\u00e2\u20ac\u2122/g, \"'\")     .replace(/\\u2019/g, \"'\") : null"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.damdescr"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$metadata.fields.associatedSKUs && $metadata.fields.associatedSKUs.length > 0 ? $metadata.fields.associatedSKUs[0]     .replace(/[\\u200B-\\u200D\\uFEFF]/g, \"\")     .replace(/\u00e2\u20ac\u2039/g, \"\")     .split(\",\")     .map(x => x.trim()) : []"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.addskuassoc"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$metadata.fields.SKUSAP && $metadata.fields.SKUSAP.length > 0 ? $metadata.fields.SKUSAP[0]     .replace(/[\\u200B-\\u200D\\uFEFF]/g, \"\")     .replace(/\u00e2\u20ac\u2039/g, \"\")     .split(\",\")     .map(x => x.trim()) : []"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.dammainsku"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "cachedSnapGptGenExpressionsRefinementMode": false,
                                            "expression": true,
                                            "snapGptEnabled": false,
                                            "value": "$file_properties != null && $file_properties.format_type != null && $embeds != null ? (     ($file_properties.format_type.toLowerCase().startsWith(\"image\")          ? $embeds.BigCommerce1500x1500JPG.url          : null)     ||     ($file_properties.format_type.toLowerCase().startsWith(\"pdf\")          ? $embeds.document_html5_viewer.url          : null)     ||     ($file_properties.format_type.toLowerCase().startsWith(\"video\")          ? $embeds.VideoWithPlayerAndDownload.url          : null)   ) : null"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.rsInternalDigitalAssetOriginalAssetUrl"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$embeds.hasOwnProperty(\"BCTestQ100\")  && $embeds.BCTestQ100.url ? $embeds.BCTestQ100.url : null"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.asseturl2048x2048"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
                                            "value": "$file_properties != null && $file_properties.format_type != null && $file_properties.format_type.toLowerCase().startsWith(\"image\") && $metadata != null && $metadata.fields != null && $metadata.fields.AutoKeywords != null && $metadata.fields.AutoKeywords.length > 0 ? $metadata.fields.AutoKeywords[0]     .replace(/[\\u200B-\\u200D\\uFEFF]/g, \"\")     .replace(/\u00e2\u20ac\u2039/g, \"\")     .split(\",\")     .map(x => x.trim()) : null"
                                        },
                                        "targetPath": {
                                            "value": "$attributes.autokeywords"
                                        }
                                    },
                                    {
                                        "expression": {
                                            "expression": true,
